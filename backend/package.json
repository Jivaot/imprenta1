{
  "name": "estampados-backend",
  "version": "1.0.0",
  "description": "Backend API para plataforma de estampados personalizados",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --experimental-modules src/index.js",
    "start": "node src/index.js",
    "build": "tsc",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "db:migrate": "node src/database/migrations/run.js",
    "db:rollback": "node src/database/migrations/rollback.js",
    "seed": "node src/database/seeds/index.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "keywords": [
    "estampados",
    "impresion",
    "digital",
    "personalizados"
  ],
  "author": "EstampadosDigitalPro",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "stripe": "^14.4.0",
    "redis": "^4.6.12",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "nodemailer": "^6.7.2",
    "axios": "^1.6.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "qs": "^6.11.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
